# ═══════════════════════════════════════════════════════════
# SoloForte — Variáveis de Ambiente (Template)
# ═══════════════════════════════════════════════════════════
# Copie este arquivo para .env.local e preencha com valores reais.
# NUNCA commite .env.local — ele contém chaves sensíveis.

# ───────────────────────────────────────────────────────────
# SUPABASE
# ───────────────────────────────────────────────────────────
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_chave_anon_aqui

# ───────────────────────────────────────────────────────────
# STADIA MAPS (Tile Provider do Mapa Padrão)
# ───────────────────────────────────────────────────────────
# Obter chave gratuita em: https://client.stadiamaps.com/signup/
# Free tier: 20k tiles/dia sem custo
STADIA_API_KEY=sua_chave_stadia_aqui

# ───────────────────────────────────────────────────────────
# OUTRAS CHAVES (futuras)
# ───────────────────────────────────────────────────────────
# Adicione aqui outras chaves de API conforme necessário
